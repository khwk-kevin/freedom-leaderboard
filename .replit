modules = ["nodejs-22"]

[agent]
expertMode = true

run = "pkill -f 'next dev' 2>/dev/null; sleep 1; npm install && npm run dev"
entrypoint = "app/page.tsx"

[[ports]]
localPort = 3000
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm ci && npm run build"]
run = ["sh", "-c", "npm run start"]
